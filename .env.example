# Copy to .env and customise. The pipeline falls back to safe defaults when
# variables are unset, so .env is optional for local development.

# Path to the trained IsolationForest joblib (read by src/api.py at startup).
# Default: results/iforest_model.joblib
# IAD_MODEL_PATH=/var/lib/iad/iforest_model.joblib

# Path to threshold.json sidecar with global + per-bearing thresholds and
# feature_order. Read by src/api.py.
# Default: results/threshold.json
# IAD_THRESHOLD_PATH=/var/lib/iad/threshold.json

# Root directory where 'make train' and 'make compare' write artefacts
# (X_test.npy, X_train_healthy.npy, comparison.parquet, figures/, etc.).
# Default: results
# IAD_RESULTS_DIR=/var/lib/iad/results
